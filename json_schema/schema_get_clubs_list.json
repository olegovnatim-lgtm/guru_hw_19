{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["count", "results"],
  "properties": {
    "count":    { "type": "integer" },
    "next":     { "type": ["string", "null"], "format": "uri" },
    "previous": { "type": ["string", "null"], "format": "uri" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["bookAuthors", "bookTitle", "created", "description", "id", "members", "modified", "owner", "publicationYear", "reviews", "telegramChatLink"],
        "properties": {
          "id":              { "type": "integer" },
          "bookTitle":       { "type": "string", "maxLength": 255 },
          "bookAuthors":     { "type": "string", "maxLength": 255 },
          "publicationYear": { "type": "integer", "minimum": -2147483648, "maximum": 2147483647 },
          "description":     { "type": "string" },
          "telegramChatLink":{ "type": "string", "format": "uri", "maxLength": 200 },
          "owner":           { "type": "integer" },
          "members":         { "type": "array", "items": { "type": "integer" } },
          "created":         { "type": "string", "format": "date-time" },
          "modified":        { "type": ["string", "null"], "format": "date-time" },
          "reviews": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["assessment", "club", "created", "id", "modified", "readPages"],
              "properties": {
                "id":         { "type": "integer" },
                "club":       { "type": "integer" },
                "user": {
                  "type": "object",
                  "required": ["id", "username"],
                  "properties": {
                    "id":       { "type": "integer" },
                    "username": { "type": "string", "maxLength": 150, "pattern": "^[\\w.@+-]+$" }
                  }
                },
                "review":     { "type": "string" },
                "assessment": { "type": "integer", "minimum": 1, "maximum": 5 },
                "readPages":  { "type": "integer", "minimum": -2147483648, "maximum": 2147483647 },
                "created":    { "type": "string", "format": "date-time" },
                "modified":   { "type": ["string", "null"], "format": "date-time" }
              }
            }
          }
        }
      }
    }
  }
}